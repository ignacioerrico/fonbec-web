<LoadingIndicator Loading="!_dataLoaded" LoadingText="Cargando datos" />

<MudSelect Label="Becario" T="int"
		   Value="SelectedStudentId" ValueChanged="OnSelectedValueChanged"
		   Disabled="!_dataLoaded"
		   Required="true" RequiredError="Este es un campo obligatorio."
		   Variant="Variant.Filled" AnchorOrigin="Origin.BottomLeft">
	@foreach (var student in _students)
	{
		<MudSelectItem T="int" Value="@student.Key">@student.DisplayName</MudSelectItem>
	}
</MudSelect>