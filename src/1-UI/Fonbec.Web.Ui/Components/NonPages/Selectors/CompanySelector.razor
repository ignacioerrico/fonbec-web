<LoadingIndicator Loading="!_dataLoaded" />

<MudSelect T="int?" Label="Empresa"
           Value="SelectedCompanyId"
           ValueChanged="OnSelectedValueChanged"
           ToStringFunc="MapKeyToDisplayName"
           Disabled="!_dataLoaded"
           Clearable="true"
           Placeholder="Seleccione una empresa"
           Variant="Variant.Filled" AnchorOrigin="Origin.BottomLeft">
    @foreach (var company in _companies)
    {
        <MudSelectItem T="int?" Value="company.Key">
            @company.DisplayName
        </MudSelectItem>
    }
</MudSelect>