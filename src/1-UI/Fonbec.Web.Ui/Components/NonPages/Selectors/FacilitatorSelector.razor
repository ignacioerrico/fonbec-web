<LoadingIndicator Loading="!_dataLoaded" />

<MudSelect T="int" Label="Mediador"
		   Value="SelectedFacilitatorId"
		   ValueChanged="OnSelectedValueChanged"
		   ToStringFunc="MapKeyToDisplayName"
		   Disabled="!_dataLoaded"
		   Required="true" RequiredError="Este es un campo obligatorio."
           Variant="Variant.Filled" AnchorOrigin="Origin.BottomLeft">
	@foreach (var facilitator in _facilitators)
	{
		<MudSelectItem T="int" Value="facilitator.Key">
			@facilitator.DisplayName
		</MudSelectItem>
	}
</MudSelect>