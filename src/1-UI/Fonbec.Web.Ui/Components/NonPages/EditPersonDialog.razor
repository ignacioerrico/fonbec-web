@using Fonbec.Web.DataAccess.Entities.Enums
@using MudBlazor
@typeparam T

<MudDialogContent>

	<MudTextField Label="Name"
				  Value="_user.UserFirstName"
				  ValueChanged="@((string value) => { _user.UserFirstName = value; OnFieldChanged(); })"
				  Immediate="true" />

	<MudTextField Label="LastName"
				  Value="_user.UserLastName"
				  ValueChanged="@((string value) => { _user.UserLastName = value; OnFieldChanged(); })"
				  Immediate="true" />

	<MudTextField Label="NickName"
				  Value="_user.UserNickName"
				  ValueChanged="@((string? value) => { _user.UserNickName = value; OnFieldChanged(); })"
				  Immediate="true" />

	<MudSelect T="Gender"
			   Value="_user.UserGender"
			   ValueChanged="@((Gender value) => { _user.UserGender = value; OnFieldChanged(); })">
		<MudSelectItem Value="Gender.Male">Masculino</MudSelectItem>
		<MudSelectItem Value="Gender.Female">Femenino</MudSelectItem>
	</MudSelect>

	<MudTextField Label="Email"
				  Value="_user.UserEmail"
				  ValueChanged="@((string value) => { _user.UserEmail = value; OnFieldChanged(); })"
				  Immediate="true" />

	<MudTextField Label="Phone"
				  Value="_user.UserPhoneNumber"
				  ValueChanged="@((string? value) => { _user.UserPhoneNumber = value; OnFieldChanged(); })"
				  Immediate="true" />

	<MudTextField Label="Notes"
				  Value="_user.UserNotes"
				  ValueChanged="@((string? value) => { _user.UserNotes = value; OnFieldChanged(); })"
				  Immediate="true" />

</MudDialogContent>

<MudDialogActions>

	<MudButton Disabled="@IsSaveDisabled"
			   OnClick="Context.Actions.CommitEditAsync"
			   Color="Color.Primary">
		Save
	</MudButton>

	<MudButton OnClick="Context.Actions.CancelEditAsync">
		Cancel
	</MudButton>

</MudDialogActions>