@inherits LayoutComponentBase

@* Required *@
<MudThemeProvider />
<MudPopoverProvider />

@* Needed for dialogs *@
<MudDialogProvider />

@* Needed for snackbars *@
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudStaticNavDrawerToggle DrawerId="nav-drawer" Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" />
        <MudText Typo="Typo.h5" Class="ml-3">FONBEC Web</MudText>
        <MudSpacer />
        <AuthorizeView>
            @{
                var chapterName = context.User.FindFirst(FonbecWebUserCustomClaim.ChapterName)?.Value
                                  ?? "GLOBAL";
            }
            <MudIcon Icon="@Icons.Material.Filled.Place" />
            <MudText Typo="Typo.h6" Class="ml-1">@chapterName</MudText>
        </AuthorizeView>
        <MudSpacer />
        <LoginDisplay />
    </MudAppBar>
    <MudDrawer id="nav-drawer" Open="true" ClipMode="DrawerClipMode.Always" Elevation="2">
        <NavMenu />
    </MudDrawer>
    <MudMainContent Class="pt-16 pa-4">
        @Body
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
