@attribute [Route(NavRoutes.Companies)]
@attribute [Authorize(Policy = nameof(CompaniesList))]
@inherits AuthenticationRequiredComponentBase

@using Fonbec.Web.DataAccess.Constants
@using Fonbec.Web.Logic.Models.Companies

<PageHeader Title="Empresas" />

<AuthorizeView Policy="@nameof(CompaniesList)">
	<MudTooltip Text="Alta de empresa"
				Arrow="true" Placement="Placement.Right"
				Color="Color.Primary">
		<MudFab Href="@NavRoutes.CompanyCreate"
				StartIcon="@Icons.Material.Filled.Add"
				Color="Color.Primary" />
	</MudTooltip>
</AuthorizeView>

<LoadingIndicator Loading="Loading"
				  If="!_viewModels.Any()"
				  ThenDisplay="No hay empresas." />

@if (_viewModels.Any())
{
	<MudDataGrid T="CompaniesListViewModel"
				 Items="_viewModels"
				 Dense="true" Hover="true" Striped="true" Bordered="true"
				 ReadOnly="false"
				 CommittedItemChanges="@(async viewModel => await CommittedItemChangesAsync(viewModel))"
				 EditMode="DataGridEditMode.Form"
				 EditTrigger="DataGridEditTrigger.Manual"
				 QuickFilter="Filter"
				 Filterable="true"
				 FilterMode="DataGridFilterMode.ColumnFilterRow"
				 FilterCaseSensitivity="DataGridFilterCaseSensitivity.CaseInsensitive"
				 StartedEditingItem="StartedEditingItem"
				 SortMode="SortMode.Multiple"
				 Class="mt-4">
		<ToolBarContent>
			<MudTextField T="string" @bind-Value="_searchString"
						  Placeholder="Buscar"
						  Clearable="true" Immediate="true"
						  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" />
		</ToolBarContent>
		<Columns>
			<HierarchyColumn/>
			<PropertyColumn Property="vm => vm.CompanyName" Title="Nombre">
				<CellTemplate>
					<AuditableItemDisplay Id="@context.Item.CompanyId"
										  ItemName="@context.Item.CompanyName"
										  AuditableViewModel="@context.Item" />
				</CellTemplate>
			</PropertyColumn>
			<PropertyColumn Property="vm => vm.CompanyEmail" Title="Correo electrónico" Required="false">
				<CellTemplate>
					<MudLink Href="@($"mailto:{context.Item.CompanyEmail}")">
						@context.Item.CompanyEmail
					</MudLink>
				</CellTemplate>
				<EditTemplate>
					<MudTextField T="string" @bind-Value="context.Item.CompanyEmail" Immediate="true"
								  Label="Correo" Variant="Variant.Outlined" Margin="Margin.Dense"
								  MaxLength="MaxLength.FonbecWebUser.Email" />
				</EditTemplate>
			</PropertyColumn>
			<PropertyColumn Property="vm => vm.CompanyPhoneNumber" Title="Teléfono" Required="false">
				<EditTemplate>
					<MudTextField T="string" @bind-Value="context.Item.CompanyPhoneNumber" Immediate="true"
								  Label="Teléfono" Variant="Variant.Outlined" Margin="Margin.Dense"
								  MaxLength="MaxLength.FonbecWebUser.PhoneNumber" />
				</EditTemplate>
			</PropertyColumn>
			<PropertyColumn Property="vm => vm.CompanyNotes" Title="Información adicional" Required="false">
				<EditTemplate>
					<MudTextField T="string" @bind-Value="context.Item.CompanyNotes" Immediate="true"
								  Label="Notas personales" Variant="Variant.Outlined" Margin="Margin.Dense"
								  MaxLength="MaxLength.Auditable.Notes" />
				</EditTemplate>
			</PropertyColumn>
			<PropertyColumn Property="vm => vm.CompanyPOCs.Count" Title="Contactos Administrativos" >
				<EditTemplate/>
			</PropertyColumn>
			<PropertyColumn Property="vm => vm.CompanySponsors.Count" Title="Padrinos" >
				<EditTemplate/>
			</PropertyColumn>
			<TemplateColumn Title="Acciones" Filterable="false" Sortable="false">
				<CellTemplate>
					<AuthorizeView Policy="@nameof(CompaniesList)" Context="innerContext">
						<Authorized>
							<MudTooltip Text="Editar" Arrow="true" Placement="Placement.Bottom" Color="Color.Primary" Delay="500">
								<MudIconButton OnClick="@context.Actions.StartEditingItemAsync"
											   Icon="@Icons.Material.Outlined.Edit" Size="@Size.Small" Color="Color.Primary" />
							</MudTooltip>
						</Authorized>
					</AuthorizeView>
				</CellTemplate>
			</TemplateColumn>
		</Columns>
		<ChildRowContent>
			<MudText Typo="Typo.h5">Contactos adminstrativos</MudText>
			@if ((context.Item.CompanyPOCs ?? []).Any())
			{
				<MudList T="string">
					@foreach (var poc in context.Item.CompanyPOCs)
					{
						<MudListItem Text="@poc" />
					}
				</MudList>
			} 
			else 
			{
				<MudText>No hay contactos administrativos para esta empresa.</MudText>
			}
			<MudText Typo="Typo.h5">Padrinos</MudText>
			@if ((context.Item.CompanySponsors ?? []).Any())
			{
				<MudList T="string">
					@foreach (var sponsor in context.Item.CompanySponsors)
					{
						<MudListItem Text="@sponsor" />
					}
				</MudList>
			} 
			else 
			{
				<MudText>No hay padrinos vinculados a esta empresa.</MudText>
			}
		</ChildRowContent>
		<PagerContent>
			<MudDataGridPager T="CompaniesListViewModel" RowsPerPageString="Filas por página:" InfoFormat="{first_item}-{last_item} of {all_items}" />
		</PagerContent>
	</MudDataGrid>
}