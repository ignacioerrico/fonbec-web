@attribute [Route(NavRoutes.CompanyCreate)]
@attribute [Authorize(Policy = nameof(CompanyCreate))]
@inherits AuthenticationRequiredComponentBase

@using Fonbec.Web.DataAccess.Constants
@using Fonbec.Web.Logic.Models

<PageHeader Title="Alta de empresa" />

<LoadingIndicator Loading="Loading" />

<MudForm @bind-IsValid="@_formValidationSucceeded">
    <MudCard>
        <MudCardContent>
            <MudText Typo="Typo.h6">Información de la empresa</MudText>

            <MudTextField T="string"
                          Label="Nombre"
                          @bind-Value="_bindModel.CompanyName"
                          Immediate="true"
                          Required="true"
                          RequiredError="Este es un campo obligatorio."
                          MaxLength="@MaxLength.Company.Name" />

            <MudTextField T="string"
                          Label="Correo electrónico"
                          @bind-Value="_bindModel.CompanyEmail"
                          MaxLength="@MaxLength.Company.Email" />

            <MudTextField T="string"
                          Label="Teléfono"
                          @bind-Value="_bindModel.CompanyPhoneNumber"
                          MaxLength="@MaxLength.Company.PhoneNumber" />

            <MudTextField T="string"
                          Label="Notas personales"
                          @bind-Value="_bindModel.CompanyNotes"
                          MaxLength="@MaxLength.Auditable.Notes" />
        </MudCardContent>
    </MudCard>

    <MudCheckBox @bind-Value="_addPointsOfContact">
        Agregar contactos administrativos
    </MudCheckBox>

    @if (_addPointsOfContact)
    {
        <MudCard Class="mt-4">
            <MudCardContent>
                <MudText Typo="Typo.h6">Contactos administrativos</MudText>
                <MudText Typo="Typo.body2" Class="mb-4">
                    Personas de contacto (que <strong>no son padrinos</strong>) para consultas administrativas.
                </MudText>

                @if (_bindModel.PointsOfContact.Any())
                {
                    <MudTable Items="_bindModel.PointsOfContact"
                              Dense="true" Hover="true" Striped="true" Bordered="true">

                        <HeaderContent>
                            <MudTh>Nombre</MudTh>
                            <MudTh>Apellido</MudTh>
                            <MudTh>Apodo</MudTh>
                            <MudTh>Correo electrónico</MudTh>
                            <MudTh>Teléfono</MudTh>
                            <MudTh></MudTh>
                        </HeaderContent>

                        <RowTemplate>
                            <MudTd>
                                <MudTextField @bind-Value="context.PocFirstName"
                                              Label="Nombre"
                                              Immediate="true"
                                              Required="true"
                                              RequiredError="El nombre es obligatorio"
                                              MaxLength="@MaxLength.PointOfContact.FirstName" />
                            </MudTd>

                            <MudTd>
                                <MudTextField @bind-Value="context.PocLastName"
                                              Label="Apellido"
                                              MaxLength="@MaxLength.PointOfContact.LastName" />
                            </MudTd>

                            <MudTd>
                                <MudTextField @bind-Value="context.PocNickName"
                                              Label="Apodo"
                                              MaxLength="@MaxLength.PointOfContact.NickName" />
                            </MudTd>

                            <MudTd>
                                <MudTextField @bind-Value="context.PocEmail"
                                              Label="Correo electrónico"
                                              MaxLength="@MaxLength.PointOfContact.Email" />
                            </MudTd>

                            <MudTd>
                                <MudTextField @bind-Value="context.PocPhoneNumber"
                                              Label="Teléfono"
                                              MaxLength="@MaxLength.PointOfContact.PhoneNumber" />
                            </MudTd>

                            <MudTd>
                                <MudTextField @bind-Value="context.PocNotes"
                                              Label="Notas"
                                              MaxLength="@MaxLength.Auditable.Notes" />
                            </MudTd>

                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Color="Color.Error"
                                               OnClick="@(() => RemovePointOfContact(context.TempId))" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
                else
                {
                    <MudText Class="my-4">No hay contactos administrativos.</MudText>
                }

                <MudButton OnClick="AddPointOfContact"
                           Disabled="!CanAddPointOfContact"
                           StartIcon="@Icons.Material.Filled.Add"
                           Variant="Variant.Outlined"
                           Color="Color.Primary"
                           Class="mt-4">
                    Agregar punto de contacto
                </MudButton>
            </MudCardContent>
        </MudCard>
    }

    <MudCheckBox @bind-Value="_linkSponsors">
        Vincular padrinos a esta empresa
    </MudCheckBox>

    @if (_linkSponsors)
    {
        <MudCard Class="mt-4">
            <MudCardContent>
                <MudStack Row="true">
                    <SponsorSelector SelectedSponsorChanged="OnSelectedSponsorChanged"
                                     ClearWhenValueChanged="true" />

                    <MudButton OnClick="RemoveAllSponsors"
                               Disabled="_bindModel.Sponsors.Count == 0"
                               Variant="Variant.Filled" Color="Color.Primary"
                               Class="mt-2">
                        Quitar todos
                    </MudButton>
                </MudStack>

                <MudText Typo="Typo.body2" Class="mt-2">
                    @((MarkupString)QtySponsorsInfo)
                </MudText>

                <MudDataGrid T="SelectableModel<int>"
                             Items="_bindModel.Sponsors"
                             Loading="Loading"
                             Dense="true" Hover="true" Striped="true" Bordered="true"
                             Class="mt-2">
                    <Columns>
                        <PropertyColumn Property="sm => sm.DisplayName" Title="Padrinos de la empresa" />
                        <TemplateColumn Title="Acciones">
                            <CellTemplate>
                                <MudTooltip Text="Quitar de la lista" Arrow="true" Placement="Placement.Bottom" Color="Color.Error" Delay="500">
                                    <MudIconButton OnClick="@(() => RemoveSponsor(context.Item))"
                                                   Icon="@Icons.Material.Outlined.Delete" Size="@Size.Small" Color="Color.Error" />
                                </MudTooltip>
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                </MudDataGrid>
            </MudCardContent>
        </MudCard>
    }

    <MudStack Row="true" Class="pt-4">
        <MudButton OnClick="Save" Disabled="SaveButtonDisabled"
                   Variant="Variant.Filled" Color="Color.Primary">
            Crear
        </MudButton>
        <MudButton Href="@NavRoutes.Companies"
                   Variant="Variant.Filled" Color="Color.Default" Class="ms-4">
            Cancelar
        </MudButton>
    </MudStack>

    <LoadingIndicator Loading="_saving" LoadingText="Guardando los datos" />
</MudForm>
