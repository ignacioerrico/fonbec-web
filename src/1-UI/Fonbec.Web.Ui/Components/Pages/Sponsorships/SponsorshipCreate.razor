@page "/becarios/{studentId:int}/padrinos/alta"
@attribute [Authorize(Policy = nameof(SponsorshipCreate))] 
@inherits AuthenticationRequiredComponentBase 

@using Fonbec.Web.DataAccess.Constants

<PageHeader Title="Apadrinar" /> 

@if (!_anySponsors) 
{
	<MudAlert Severity="Severity.Error"> No hay Padrinos. Para apadrinar se requiere 

		<MudLink 
			Href="@NavRoutes.SponsorCreate" 
			Typo="Typo.body2"> al menos un padrino 
		</MudLink>. 

	</MudAlert>
}

<LoadingIndicator Loading="Loading" />

<MudForm @bind-IsValid="_formValidationSucceeded" 
				Disabled="IsFormDisabled">

	<SponsorSelector @bind-SelectedSponsorId="_bindModel.SponsorId" 
					OnSponsorsLoaded="OnSponsorsLoaded" />

	<MudDatePicker Label="Fecha Inicio"
				   Editable="true"
				   @bind-Date="_bindModel.SponsorshipStartDate"
				   Placeholder="Select Date"
				   Clearable="true"
				   Required="true"
				   MinDate="@DateTime.Today" />

	<MudCheckBox @bind-Value="_knowEndDate"
				 Label="Conozco la fecha de fin"
				 Color="Color.Primary" />

	<MudDatePicker Label="Fecha Fin"
				   Editable="true"
				   Disabled="@(!_knowEndDate)"
				   @bind-Date="_bindModel.SponsorshipEndDate"
				   Placeholder="Select Date"
				   Clearable="true"
				   MinDate="_bindModel.SponsorshipStartDate" />
</MudForm>

<MudStack Row="true" Class="pt-4">
	@if (DatesAreInvalid)
	{
		<MudAlert Severity="Severity.Error">
			La fecha de fin no puede ser menor a la fecha de inicio
		</MudAlert>
	}
	
	<!--Question for Ignacio, validations in UI is enough?-->
	<MudButton OnClick="Save"
			   Disabled="SaveButtonDisabled || DatesAreInvalid"
			   Variant="Variant.Filled"
			   StartIcon="@Icons.Material.Filled.Save"
			   Color="Color.Primary">
			   Crear
	</MudButton>

	<MudButton Href="@NavRoutes.Students"
			   Variant="Variant.Filled"
			   Color="Color.Default"
			   Class="ms-4">
			   Cancelar
	</MudButton>

</MudStack>

<LoadingIndicator Loading="_saving" LoadingText="Guardando los datos" />