@page "/becarios/{studentId:int}/padrinos"
@using Fonbec.Web.Logic.Models.Sponsorships
@using Microsoft.EntityFrameworkCore

@inject NavigationManager Navigation
@attribute [Authorize(Policy = nameof(SponsorshipsList))]
@inherits AuthenticationRequiredComponentBase


<PageHeader Title="@($"Padrinos de: {StudentFullName}")" />

    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">

    <MudButton Href="@NavRoutes.Students"
               StartIcon="@Icons.Material.Filled.ArrowBack"
               Variant="Variant.Text"
               Color="Color.Default">
        Volver
    </MudButton>

    <AuthorizeView Policy="@nameof(SponsorshipCreate)">
        <MudButton Href="@NavRoutes.SponsorshipCreate(StudentId)"
                   StartIcon="@Icons.Material.Filled.Add"
                   Variant="Variant.Filled"
                   Color="Color.Primary">
            Apadrinar
        </MudButton>
    </AuthorizeView>

    <MudSpacer />

    </MudStack>
<LoadingIndicator Loading="Loading"
                  If="!_viewModels.Any()"
                  ThenDisplay="No tiene padrinos aun." />

@if (_viewModels.Any())
{
    <MudDataGrid T="SponsorshipsListViewModel"
                 Items="_viewModels"
                 Dense="true" Hover="true" Striped="true" Bordered="true">
        
        <Columns>
            <TemplateColumn Title="Padrino">
                <CellTemplate>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        @if (context.Item.IsCompany)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Small" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                        }
                        <MudText Typo="Typo.body2">@context.Item.SponsorOrCompanyName</MudText>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>

            <TemplateColumn Title="Estado"> 
                <CellTemplate>
                    - <!--to do-->
                </CellTemplate>
            </TemplateColumn>

            <PropertyColumn Property="vm => vm.SponsorshipStartDate" Title="Desde" Required="false">
                <CellTemplate>
                    <MudText Typo="Typo.body2">@(context.Item.SponsorshipStartDate.ToString("dd/MM/yyyy"))</MudText>
                </CellTemplate>
            </PropertyColumn>

            <PropertyColumn Property="vm => vm.SponsorshipEndDate" Title="Hasta" Required="false">
                <CellTemplate>
                    <MudText Typo="Typo.body2">@(context.Item.SponsorshipEndDate?.ToString("dd/MM/yyyy") ?? "-")</MudText>
                </CellTemplate>
            </PropertyColumn>

            <TemplateColumn Title="Acciones" Filterable="false" Sortable="false">
                <CellTemplate>
                    <AuthorizeView Policy="@nameof(SponsorshipCreate)" Context="innerContext">
                        <MudTooltip Text="Editar" Arrow="true" Placement="Placement.Bottom" Color="Color.Primary" Delay="500">
                            <MudIconButton OnClick="@context.Actions.StartEditingItemAsync"
                                           Icon="@Icons.Material.Outlined.Edit"
                                           Size="@Size.Small"
                                           Color="Color.Primary" />
                        </MudTooltip>
                    </AuthorizeView>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="SponsorshipsListViewModel" RowsPerPageString="Filas por página:" InfoFormat="{first_item}-{last_item} of {all_items}" />
        </PagerContent>
    </MudDataGrid>
}