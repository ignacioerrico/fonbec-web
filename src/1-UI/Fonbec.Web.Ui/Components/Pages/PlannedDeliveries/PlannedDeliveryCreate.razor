@attribute [Route(NavRoutes.PlannnedDeliveryCreate)]
@attribute [Authorize(Policy = nameof(PlannedDeliveryCreate))]
@inherits AuthenticationRequiredComponentBase

@using Fonbec.Web.DataAccess.Constants

<PageHeader Title="Planificación de envío" />

<LoadingIndicator Loading="Loading" />

<MudForm @bind-IsValid="@_formValidationSucceeded">
    <MudDatePicker Label="Mes y Año"
                   @bind-Date="_bindModel.PlanStartsOn"
                   MinDate="_minDate"
                   OpenTo="OpenTo.Month"
                   FixDay="1"
                   DateFormat="MMMM \d\e yyyy"
                   TitleDateFormat="MMM yyyy"
                   Culture="@System.Globalization.CultureInfo.GetCultureInfo("es-AR")"
                   Required="true" RequiredError="Se debe especificar el mes y el año de recolección de cartas."
                   Validation="(Func<DateTime?, string?>)ValidatePlanIsNotDuplicate" />

    <MudTextField T="string" Label="Notas"
                  @bind-Value="_bindModel.PlanNotes"
                  MaxLength="MaxLength.Auditable.Notes" />
</MudForm>

<MudStack Row="true" Class="pt-4">
    <MudButton OnClick="Save" Disabled="SaveButtonDisabled"
               Variant="Variant.Filled" Color="Color.Primary">
        Crear
    </MudButton>
    <MudButton Href="@NavRoutes.PlannedDeliveries"
               Variant="Variant.Filled" Color="Color.Default" Class="ms-4">
        Cancelar
    </MudButton>
</MudStack>

<LoadingIndicator Loading="_saving" LoadingText="Guardando los datos" />