@page "/Account/LoginWith2fa"

@using System.ComponentModel.DataAnnotations
@using Fonbec.Web.DataAccess.Entities
@using Microsoft.AspNetCore.Identity

@inject SignInManager<FonbecWebUser> SignInManager
@inject UserManager<FonbecWebUser> UserManager
@inject IdentityRedirectManager RedirectManager
@inject ILogger<LoginWith2fa> Logger
@inject NavigationManager NavigationManager

<PageTitle>Autenticación en dos pasos</PageTitle>

<MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true">Autenticación en dos pasos</MudText>
<MudText Typo="Typo.body2" Align="Align.Center" Class="mb-6 mud-text-secondary">
    Tu cuenta está protegida con una app de autenticación. Ingresá el código de verificación.
</MudText>

<StatusMessage Message="@_message" />

<EditForm Model="Input" FormName="login-with-2fa" OnValidSubmit="OnValidSubmitAsync" method="post">
    <input type="hidden" name="ReturnUrl" value="@ReturnUrl" />
    <input type="hidden" name="RememberMe" value="@RememberMe" />
    <DataAnnotationsValidator />

    <MudStack Spacing="3">
        <MudStaticTextField For="@(() => Input.TwoFactorCode)" @bind-Value="Input.TwoFactorCode"
                            Label="Código de autenticación" InputId="two-factor-code"
                            UserAttributes="@(new() { { "autocomplete", "one-time-code" }, { "aria-required", "true" } })" />
        <MudStaticCheckBox For="@(() => Input.RememberMachine)" @bind-Value="Input.RememberMachine">
            Recordar este dispositivo
        </MudStaticCheckBox>
        <MudStaticButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" FormAction="FormAction.Submit">
            Iniciar sesión
        </MudStaticButton>
    </MudStack>
</EditForm>

<div class="auth-layout__links mt-6">
    <MudLink Href="@RecoveryCodeUrl">Iniciar sesión con un código de recuperación</MudLink>
    <MudLink Href="Account/Login">Volver al inicio de sesión</MudLink>
</div>

@code {
    private string? _message;
    private FonbecWebUser _user = null!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    private bool RememberMe { get; set; }

    private string RecoveryCodeUrl =>
        NavigationManager.GetUriWithQueryParameters("Account/LoginWithRecoveryCode", new Dictionary<string, object?> { ["ReturnUrl"] = ReturnUrl });

    protected override async Task OnInitializedAsync()
    {
        _user = await SignInManager.GetTwoFactorAuthenticationUserAsync() ??
            throw new InvalidOperationException("Unable to load two-factor authentication user.");
    }

    private async Task OnValidSubmitAsync()
    {
        var authenticatorCode = Input.TwoFactorCode!.Replace(" ", string.Empty).Replace("-", string.Empty);
        var result = await SignInManager.TwoFactorAuthenticatorSignInAsync(authenticatorCode, RememberMe, Input.RememberMachine);
        var userId = await UserManager.GetUserIdAsync(_user);

        if (result.Succeeded)
        {
            Logger.LogInformation("User with ID '{UserId}' logged in with 2fa.", userId);
            RedirectManager.RedirectTo(ReturnUrl);
        }
        else if (result.IsLockedOut)
        {
            Logger.LogWarning("User with ID '{UserId}' account locked out.", userId);
            RedirectManager.RedirectTo("Account/Lockout");
        }
        else
        {
            Logger.LogWarning("Invalid authenticator code entered for user with ID '{UserId}'.", userId);
            _message = "Error: Código de autenticación inválido.";
        }
    }

    private sealed class InputModel
    {
        [Required]
        [StringLength(7, ErrorMessage = "El {0} debe tener entre {2} y {1} caracteres.", MinimumLength = 6)]
        [DataType(DataType.Text)]
        [Display(Name = "Código de autenticación")]
        public string? TwoFactorCode { get; set; }

        [Display(Name = "Recordar este dispositivo")]
        public bool RememberMachine { get; set; }
    }
}
